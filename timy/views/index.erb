<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Timy Browser Simulation</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main id="layout-root" class="layout">
      <section id="input-panel" class="panel channel-mail">
        <h1>Timy Simulator</h1>
        <p class="subtitle">Enter one message per line and process immediately.</p>

        <form id="entry-form">
          <fieldset class="channel-picker" role="radiogroup" aria-label="Select channel">
            <legend>Channel</legend>
            <label for="channel-mail" class="channel-option active">
              <input id="channel-mail" type="radio" name="channel" value="mail" checked />
              <span class="emoji" aria-hidden="true">✉️</span>
              <span>Mail</span>
            </label>
            <label for="channel-sms" class="channel-option">
              <input id="channel-sms" type="radio" name="channel" value="sms" />
              <span class="emoji" aria-hidden="true">💬</span>
              <span>SMS</span>
            </label>
            <label for="channel-whatsapp" class="channel-option">
              <input id="channel-whatsapp" type="radio" name="channel" value="whatsapp" />
              <span class="emoji" aria-hidden="true">🟢</span>
              <span>WhatsApp</span>
            </label>
          </fieldset>

          <section id="composer-shell" class="composer-shell composer-mail">
            <header id="composer-meta-mail" class="composer-meta">
              <div class="meta-row"><span class="meta-label">From:</span> Timy Demo</div>
              <div class="meta-row"><span class="meta-label">To:</span> Project mailbox</div>
              <div class="meta-row"><span class="meta-label">Subject:</span> Daily work log</div>
            </header>

            <header id="composer-meta-sms" class="composer-meta">
              <div class="meta-pill">SMS Thread</div>
              <div class="meta-hint">Short updates, one line per item</div>
            </header>

            <header id="composer-meta-whatsapp" class="composer-meta">
              <div class="meta-pill whatsapp">WhatsApp Chat</div>
              <div class="meta-hint">Team chat style updates</div>
            </header>

            <label>
              Message Lines
              <textarea name="message" rows="10" placeholder="Worked 2h on Alpha&#10;30m sprint planning" required></textarea>
            </label>
          </section>
          <div class="form-actions">
            <button type="submit">Submit and Process</button>
            <button id="toggle-results" data-results-toggle type="button" class="toggle-results">Hide Results</button>
          </div>
          <div id="status-line" class="status-line">
            <span id="status-spinner" class="status-spinner" aria-hidden="true"></span>
            <span id="status-text">Loading...</span>
            <span id="status-elapsed" class="status-elapsed"></span>
          </div>
          <section id="latest-confirmation" class="latest-confirmation hidden" aria-live="polite"></section>
        </form>
      </section>

      <section id="results-panel" class="panel" hidden>
        <div class="results-head">
          <h2>Results</h2>
          <button id="toggle-results-secondary" data-results-toggle type="button" class="toggle-results">Hide Results</button>
        </div>
        <div id="error-box" class="error-box" aria-live="polite"></div>
        <div id="summary" class="summary"></div>
        <div id="entries" class="entries"></div>
        <div id="followups" class="followups"></div>
      </section>
    </main>

    <script src="/app.js"></script>
  </body>
</html>
