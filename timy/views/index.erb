<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Timy Browser Simulation</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="layout">
      <section id="input-panel" class="panel">
        <h1>Timy Simulator</h1>
        <p class="subtitle">Enter a message and process it immediately.</p>

        <form id="entry-form">
          <label>
            Channel
            <select name="channel" required>
              <option value="mail">Mail (niels@example.com)</option>
              <option value="sms">SMS (+3165892356)</option>
              <option value="whatsapp">WhatsApp (+3156455645)</option>
            </select>
          </label>
          <label>
            Message
            <textarea name="message" rows="10" placeholder="One entry per line&#10;Worked 2h on Alpha&#10;30m sprint planning" required></textarea>
          </label>
          <button type="submit">Submit and Process</button>
        </form>
      </section>

      <section id="results-panel" class="panel">
        <h2>Results</h2>
        <div id="status-line">Loading...</div>
        <div id="error-box" class="error-box" aria-live="polite"></div>
        <div id="summary" class="summary"></div>
        <div id="entries" class="entries"></div>
        <div id="followups" class="followups"></div>
      </section>
    </main>

    <script src="/app.js"></script>
  </body>
</html>
